# Enable Bzlmod.
common --enable_bzlmod
common --noenable_workspace

# Use C++20.
build --cxxopt=-std=c++20
build --host_cxxopt=-std=c++20

# Disable Bazel's strict include layering check. Without this, transitive
# includes are forbidden, exposing missing #include directives in dependencies.
build --features=-layering_check
build --host_features=-layering_check
