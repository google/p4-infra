digraph ActionSet {
  rankdir=LR;
  fontname="sans-serif";
  node [fontname="sans-serif", fontsize=11, shape=box, style="rounded,filled",
        penwidth=1.2, width=3.4, fillcolor="#ffffff", color="#5f6368"];

  subgraph cluster_entry_4 {
    label = "Table Entry A";
    fontsize = 12; fontcolor = "#5f6368";
    style = rounded; bgcolor = "#f1f3f4"; color = "#bdc1c6";

    Match4 [label="Match Fields\nvrf_id = 10"];

    subgraph cluster_group_4 {
      label = "Group";
      fontsize = 11; fontcolor = "#5f6368";
      style = rounded; bgcolor = "#e8eaed"; color = "#9aa0a6";
      Act4d [label="drop (4)"];
      Act4c [label="route (3)\nport_id = \"eth0\""];
      Act4b [label="set_class (2)\nclass_id = \"salsa\""];
      Act4a [label="set_class (1)\nclass_id = \"taco\""];
    }
  }

  subgraph cluster_out_4 {
    label = "Generated outgoing references";
    fontsize = 12; fontcolor = "#1a73e8";
    style = rounded; bgcolor = "#f8f9fa"; color = "#80868b";

    R4d [fillcolor="#fce8e6", color="#c5221f", fontcolor="#c5221f",
         label="Group Table A → Table B\nvrf_id → vrf_id : 10"];

    R4c [fillcolor="#e0f2f1", color="#00796b", fontcolor="#00796b",
         label="Group Table A → Table B\nvrf_id → vrf_id : 10\nroute.port_id → port_id : \"eth0\""];

    R4b [fillcolor="#f1f3f4", color="#bdc1c6", fontcolor="#5f6368",
         label="Group Table A → Table B\nvrf_id → vrf_id : 10\nset_class.class_id → class_id : \"salsa\""];

    R4a [fillcolor="#fef7e0", color="#b06000", fontcolor="#b06000",
         label="Group Table A → Table B\nvrf_id → vrf_id : 10\nset_class.class_id → class_id : \"taco\""];

  }

  // Balance vertical barycenter pull across the entire outer containers:
  Match4 -> R4a [style=invis];
  Act4d -> R4d [style=invis];
}
