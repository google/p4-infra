ReadResponse test: valid ternary table
=========================================================================

--- PD (Input):
table_entries {
  ternary_table_entry {
    match {
      normal {
        value: "0x052"
        mask: "0x273"
      }
    }
    action {
      do_thing_3 {
        arg1: "0x01234567"
        arg2: "0x01234568"
      }
    }
    priority: 32
  }
}

--- IR:
entities {
  table_entry {
    table_name: "ternary_table"
    matches {
      name: "normal"
      ternary {
        value {
          hex_str: "0x052"
        }
        mask {
          hex_str: "0x273"
        }
      }
    }
    priority: 32
    action {
      name: "do_thing_3"
      params {
        name: "arg1"
        value {
          hex_str: "0x01234567"
        }
      }
      params {
        name: "arg2"
        value {
          hex_str: "0x01234568"
        }
      }
    }
  }
}

--- PI:
entities {
  table_entry {
    table_id: 33554435
    match {
      field_id: 1
      ternary {
        value: "R"
        mask: "\002s"
      }
    }
    action {
      action {
        action_id: 16777219
        params {
          param_id: 1
          value: "\001#Eg"
        }
        params {
          param_id: 2
          value: "\001#Eh"
        }
      }
    }
    priority: 32
  }
}


